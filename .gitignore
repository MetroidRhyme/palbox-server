# ===== Local config (never commit real values) =====
config.ps1
PalWorldSettings.ini
GameUserSettings.ini
.env
.wrangler/

# ===== Live data / runtime state / logs =====
.r2_stage/
SaveLibrary/
playtime-log*.json
playtime-glitch.log
egg_notify.json
.egg_notify_state.json
server_messages.jsonl
metrics-log.jsonl
maintenance.log
.palbox_deploy_state.json
.palbox_r2_sync_state.json
.palbox_msg_push_state.json
.palbox_offmachine_backup_state.json
# Rotating timestamped safety backups the dashboard writes before rewriting the canonical
# map store -- local artifacts, not source (e.g. confirmed_locations.backup_20260710_125944.json).
confirmed_locations.backup_*.json
manager-config.json
sync_public_data.log
prefs/
# The "prefs/" line above only matches a directory -- also catch a stray bare file named
# "prefs" (no extension), which has shown up before with no clear source and isn't
# actually referenced by any script (the real prefs feature lives in R2, not on disk).
prefs
*.flag
__pycache__/
*.pyc

# ===== Generated output (regenerated by the scripts) =====
public/
PalAssets/
# All pal_icons are regenerated by gen_pal_icons.py: work/element icons are re-fetched from
# paldb.cc; the 9 passive-pill PNGs are drawn procedurally (authored primitives). Nothing
# game-owned is committed.
pal_icons/*
pal_species.json
pal_skills.json
pal_passives.json
pal_names.json
effigies.json

# ===== Game install (NOT ours to redistribute) =====
# This repo is meant to live in the PalWorld server root. Ignore the whole game install.
Engine/
Pal/
Mods/
_CommonRedist/
steamapps/
Manifest_*.txt
steam_appid.txt
*.exe
*.dll
PalServer*
steamcmd/

